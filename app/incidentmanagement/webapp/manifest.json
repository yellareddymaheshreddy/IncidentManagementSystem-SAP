{
  "_version": "1.85.0",
  "sap.app": {
    "id": "com.amista.incidentmanagement.incidentmanagement",
    "type": "application",
    "i18n": "i18n/i18n.properties",
    "applicationVersion": {
      "version": "0.0.1"
    },
    "title": "{{appTitle}}",
    "description": "{{appDescription}}",
    "resources": "resources.json",
    "sourceTemplate": {
      "id": "@sap/generator-fiori:basic",
      "version": "1.26.0",
      "toolsId": "ec1917c7-5b94-4d1f-830b-4bdabe183915"
    },
    "dataSources": {
      "mainService": {
        "uri": "/odata/v4/employee/",
        "type": "OData",
        "settings": {
          "annotations": [],
          "odataVersion": "4.0"
        }
      },
      "dashboardService": {
        "uri": "/odata/v4/dashboard/",
        "type": "OData",
        "settings": {
          "odataVersion": "4.0"
        }
      }
    },
    "crossNavigation": {
      "inbounds": {
        "incidentmanagement-display": {
          "semanticObject": "incidentmanagement",
          "action": "display",
          "title": "{{incidentmanagement-display.flpTitle}}",
          "subTitle": "{{incidentmanagement-display.flpSubtitle}}",
          "signature": {
            "parameters": {},
            "additionalParameters": "allowed"
          }
        }
      }
    }
  },
  "sap.ui": {
    "technology": "UI5",
    "icons": {
      "icon": "",
      "favIcon": "",
      "phone": "",
      "phone@2": "",
      "tablet": "",
      "tablet@2": ""
    },
    "deviceTypes": {
      "desktop": true,
      "tablet": true,
      "phone": true
    }
  },
  "sap.ui5": {
    "flexEnabled": false,
    "dependencies": {
      "minUI5Version": "1.149.0",
      "libs": {
        "sap.m": {},
        "sap.ui.core": {}
      }
    },
    "contentDensities": {
      "compact": true,
      "cozy": true
    },
    "models": {
      "i18n": {
        "type": "sap.ui.model.resource.ResourceModel",
        "settings": {
          "bundleName": "com.amista.incidentmanagement.incidentmanagement.i18n.i18n"
        }
      },
      "": {
        "dataSource": "mainService",
        "preload": true,
        "settings": {
          "operationMode": "Server",
          "autoExpandSelect": true,
          "earlyRequests": true
        }
      },
      "dashboardService": {
        "dataSource": "dashboardService",
        "preload": true
      }
    },
    "resources": {
      "css": [
        {
          "uri": "css/style.css"
        }
      ]
    },
    "routing": {
      "config": {
        "routerClass": "sap.m.routing.Router",
        "controlAggregation": "pages",
        "controlId": "app",
        "transition": "slide",
        "type": "View",
        "viewType": "XML",
        "path": "com.amista.incidentmanagement.incidentmanagement.view",
        "async": true,
        "viewPath": "com.amista.incidentmanagement.incidentmanagement.view"
      },
      "routes": [
        {
          "name": "RouteHome",
          "pattern": ":?query:",
          "target": [
            "TargetHome"
          ]
        },
        {
          "name": "CreateIncident",
          "pattern": "createIncident",
          "target": "CreateIncident"
        },
        {
          "name": "IncidentDetail",
          "pattern": "incident/{incidentId}",
          "target": "IncidentDetail"
        },
        {
          "name": "Dashboard",
          "pattern": "dashboard",
          "target": "Dashboard"
        }
      ],
      "targets": {
        "TargetHome": {
          "id": "Home",
          "name": "Home"
        },
        "CreateIncident": {
          "id": "CreateIncident",
          "name": "incidents.CreateIncident"
        },
        "IncidentDetail": {
          "id": "IncidentDetail",
          "name": "incidents.IncidentDetail"
        },
        "Dashboard": {
          "id": "Dashboard",
          "name": "Dashboard"
        }
      }
    },
    "rootView": {
      "viewName": "com.amista.incidentmanagement.incidentmanagement.view.App",
      "type": "XML",
      "id": "App",
      "async": true
    }
  }
}