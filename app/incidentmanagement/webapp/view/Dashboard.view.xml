<mvc:View
    xmlns:cards="sap.f.cards"
    controllerName="com.amista.incidentmanagement.incidentmanagement.controller.Dashboard"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:f="sap.f"
    xmlns:layout="sap.ui.layout"
    xmlns:core="sap.ui.core"
    xmlns:viz="sap.viz.ui5.controls"
    xmlns:viz.data="sap.viz.ui5.data"
    xmlns:viz.feeds="sap.viz.ui5.controls.common.feeds"
    xmlns:m="sap.m"
    xmlns:c="sap.suite.ui.microchart"
>
    <Page title="Incident Monitoring Dashboard">
        <content>
            <VBox class="sapUiMediumMargin">
                <!-- Header -->

                <Title
                    text="Operations Overview"
                    level="H1"
                />

                <Text
                    text="Monitor incidents, alerts, SLA compliance and operational trends."
                />

                <!-- KPI Cards -->

                <layout:Grid
                    defaultSpan="XL3 L3 M6 S12"
                    hSpacing="1"
                    vSpacing="1"
                    class="sapUiMediumMarginTop"
                >
                    <!-- Total Incidents -->
                    <!-- Total Incidents -->
    <GenericTile
        header="Total Incidents"
        subheader="Overall incidents"
        class="sapUiTinyMargin">
        <TileContent footer="Current Volume">
            <NumericContent
                value="{dashboard>/totalIncidents}"
                valueColor="Neutral"
                icon="sap-icon://activity-items"
                withMargin="false"/>
        </TileContent>
    </GenericTile>

    <!-- Open Incidents -->
    <GenericTile
        header="Open Incidents"
        subheader="Needs Attention"
        class="sapUiTinyMargin">
        <TileContent footer="Requires Action">
            <NumericContent
                value="{dashboard>/openIncidents}"
                valueColor="Critical"
                icon="sap-icon://warning2"
                withMargin="false"/>
        </TileContent>
    </GenericTile>

    <!-- Critical Incidents -->
    <GenericTile
        header="Critical Incidents"
        subheader="Highest Priority"
        class="sapUiTinyMargin">
        <TileContent footer="Immediate Action">
            <NumericContent
                value="{dashboard>/criticalIncidents}"
                valueColor="Error"
                icon="sap-icon://alert"
                withMargin="false"/>
        </TileContent>
    </GenericTile>

    <!-- SLA Breaches -->
    <GenericTile
        header="SLA Breaches"
        subheader="Compliance Status"
        class="sapUiTinyMargin">
        <TileContent footer="Past Due">
            <NumericContent
                value="{dashboard>/slaBreaches}"
                valueColor="Error"
                icon="sap-icon://lateness"
                withMargin="false"/>
        </TileContent>
    </GenericTile>
                </layout:Grid>

                <layout:Grid
                    defaultSpan="XL4 L4 M6 S12"
                    hSpacing="1"
                    vSpacing="1"
                >
                    <viz:VizFrame
                        id="statusDonutChart"
                        vizType="donut"
                        width="100%"
                        height="400px"
                        vizProperties="{ title: {text : 'Status Distribution', visible : true}}"
                    >
                        <viz:dataset>
                            <viz.data:FlattenedDataset data="{chart>/value}">
                                <viz.data:dimensions>
                                    <viz.data:DimensionDefinition
                                        name="Status"
                                        value="{chart>status}"
                                    />
                                </viz.data:dimensions>

                                <viz.data:measures>
                                    <viz.data:MeasureDefinition
                                        name="Incidents"
                                        value="{chart>count}"
                                    />
                                </viz.data:measures>
                            </viz.data:FlattenedDataset>
                        </viz:dataset>

                        <viz:feeds>
                            <viz.feeds:FeedItem
                                uid="size"
                                type="Measure"
                                values="Incidents"
                            />

                            <viz.feeds:FeedItem
                                uid="color"
                                type="Dimension"
                                values="Status"
                            />
                        </viz:feeds>
                    </viz:VizFrame>

                    <viz:VizFrame
                        vizProperties="{ title: {text : 'Incident Trend', visible : true}}"
                        id="incidentStatusChart"
                        vizType="column"
                        legendVisible="false"
                        width="100%"
                        height="400px"
                    >
                        <viz:dataset>
                            <viz.data:FlattenedDataset data="{trend>/value}">
                                <viz.data:dimensions>
                                    <viz.data:DimensionDefinition
                                        name="Date"
                                        value="{trend>DATE}"
                                    />
                                </viz.data:dimensions>

                                <viz.data:measures>
                                    <viz.data:MeasureDefinition
                                        name="Incidents"
                                        value="{trend>INCIDENTCOUNT}"
                                    />
                                </viz.data:measures>
                            </viz.data:FlattenedDataset>
                        </viz:dataset>

                        <viz:feeds>
                            <viz.feeds:FeedItem
                                uid="valueAxis"
                                type="Measure"
                                values="Incidents"
                            />

                            <viz.feeds:FeedItem
                                uid="categoryAxis"
                                type="Dimension"
                                values="Date"
                            />
                        </viz:feeds>
                    </viz:VizFrame>

                    <viz:VizFrame
                        id="slaBreachChart"
                        vizType="column"
                        width="100%"
                        legendVisible="false"
                        height="400px"
                        vizProperties="{ title: {text : 'SLA Breach Count', visible : true}}"
                    >
                        <viz:dataset>
                            <viz.data:FlattenedDataset data="{sla>/value}">
                                <viz.data:dimensions>
                                    <viz.data:DimensionDefinition
                                        name="Priority"
                                        value="{sla>PRIORITY}"
                                    />
                                </viz.data:dimensions>

                                <viz.data:measures>
                                    <viz.data:MeasureDefinition
                                        name="Breach Count"
                                        value="{sla>BREACHCOUNT}"
                                    />
                                </viz.data:measures>
                            </viz.data:FlattenedDataset>
                        </viz:dataset>

                        <viz:feeds>
                            <viz.feeds:FeedItem
                                uid="valueAxis"
                                type="Measure"
                                values="Breach Count"
                            />

                            <viz.feeds:FeedItem
                                uid="categoryAxis"
                                type="Dimension"
                                values="Priority"
                            />
                        </viz:feeds>
                    </viz:VizFrame>
                </layout:Grid>

                <!-- Active Alerts -->

                <f:Card class="sapUiMediumMarginTop">
                    <f:header>
                        <cards:Header title="Pending Alerts" />
                    </f:header>

                    <f:content>
                        <Table items="{alerts>/value}">
                            <columns>
                                <Column>
                                    <Text text="Title" />
                                </Column>

                                <Column>
                                    <Text text="Priority" />
                                </Column>

                                <Column>
                                    <Text text="Severity" />
                                </Column>

                                <Column>
                                    <Text text="Age (Minutes)" />
                                </Column>
                            </columns>

                            <items>
                                <ColumnListItem>
                                    <cells>
                                        <Text text="{alerts>title}" />

                                        <ObjectStatus
                                            text="{alerts>priority}"
                                            state="Error"
                                        />

                                        <ObjectStatus
                                            text="{alerts>severity}"
                                            state="Error"
                                        />

                                        <ObjectNumber
                                            number="{alerts>ageMinutes}"
                                        />
                                    </cells>
                                </ColumnListItem>
                            </items>
                        </Table>
                    </f:content>
                </f:Card>
            </VBox>
        </content>
    </Page>
</mvc:View>
