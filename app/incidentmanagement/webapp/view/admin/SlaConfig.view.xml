<mvc:View
    controllerName="com.amista.incidentmanagement.incidentmanagement.controller.SlaConfig"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:f="sap.f">
    <Page title="SLA Configurations">
        <content>
            <VBox class="sapUiMediumMargin">
                <Table id="slaTable" items="{
                    path: 'adminService>/SLAConfigurations',
                    parameters: {
                        $$updateGroupId: 'slaUpdateGroup'
                    }
                }" growing="true">
                    <headerToolbar>
                        <OverflowToolbar>
                            <Title text="SLA Priority Profiles" level="H2"/>
                            <ToolbarSpacer/>
                            <Button text="Save Changes" type="Emphasized" icon="sap-icon://save" press=".onSaveChanges"/>
                        </OverflowToolbar>
                    </headerToolbar>
                    <columns>
                        <Column width="120px"><Text text="Priority"/></Column>
                        <Column minScreenWidth="200px"><Text text="Description"/></Column>
                        <Column width="180px"><Text text="Response Time (Hours)"/></Column>
                        <Column width="180px"><Text text="Resolution Time (Hours)"/></Column>
                        <Column width="150px" hAlign="Center"><Text text="Business Hours Only"/></Column>
                    </columns>
                    <items>
                        <ColumnListItem>
                            <cells>
                                <Label text="{adminService>priority}" design="Bold"/>
                                <Input value="{adminService>description}"/>
                                <StepInput value="{adminService>responseTime}" min="1" step="1"/>
                                <StepInput value="{adminService>resolutionTime}" min="1" step="1"/>
                                <Switch state="{adminService>businessHoursOnly}"/>
                            </cells>
                        </ColumnListItem>
                    </items>
                </Table>
            </VBox>
        </content>
    </Page>
</mvc:View>
