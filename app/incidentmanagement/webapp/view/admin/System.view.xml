<mvc:View
    controllerName="com.amista.incidentmanagement.incidentmanagement.controller.System"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:core="sap.ui.core">
    <Page title="Systems Management">
        <content>
            <VBox class="sapUiMediumMargin">
                <Table id="systemsTable" items="{adminService>/Systems}" mode="SingleSelectMaster" growing="true">
                    <headerToolbar>
                        <OverflowToolbar>
                            <Title text="Registered Enterprise Systems" level="H2"/>
                            <ToolbarSpacer/>
                            <Button text="Add System" type="Default" icon="sap-icon://add" press=".onAddSystem"/>
                            <Button text="Delete Selected" type="Reject" icon="sap-icon://delete" press=".onDeleteSystem"/>
                            <Button text="Save Changes" type="Emphasized" icon="sap-icon://save" press=".onSaveChanges"/>
                        </OverflowToolbar>
                    </headerToolbar>
                    <columns>
                        <Column width="180px"><Text text="System ID"/></Column>
                        <Column minScreenWidth="200px"><Text text="System Name"/></Column>
                        <Column minScreenWidth="300px"><Text text="Description"/></Column>
                        <Column minScreenWidth="200px"><Text text="Owner"/></Column>
                    </columns>
                    <items>
                        <ColumnListItem>
                            <cells>
                                <Label text="{adminService>ID}" design="Bold"/>
                                <Input value="{adminService>name}"/>
                                <Input value="{adminService>description}"/>
                                <ComboBox selectedKey="{adminService>owner_ID}" items="{adminService>/Users}" selectedItem="{adminService>ID}">
                                    <core:Item key="{adminService>ID}" text="{adminService>name}"/>
                                </ComboBox>
                            </cells>
                        </ColumnListItem>
                    </items>
                </Table>
            </VBox>
        </content>
    </Page>
</mvc:View>
