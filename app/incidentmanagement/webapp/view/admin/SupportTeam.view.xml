<mvc:View
    controllerName="com.amista.incidentmanagement.incidentmanagement.controller.SupportTeam"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:core="sap.ui.core">
    <Page title="Support Teams Management">
        <content>
            <VBox class="sapUiMediumMargin">
                <Table id="teamsTable" items="{
                    path: 'adminService>/SupportTeams',
                    parameters: {
                        $$updateGroupId: 'teamUpdateGroup'
                    }
                }" mode="SingleSelectMaster" growing="true">
                    <headerToolbar>
                        <OverflowToolbar>
                            <Title text="Registered Support Teams" level="H2"/>
                            <ToolbarSpacer/>
                            <Button text="Add Team" type="Default" icon="sap-icon://add" press=".onAddTeam"/>
                            <Button text="Delete Selected" type="Reject" icon="sap-icon://delete" press=".onDeleteTeam"/>
                            <Button text="Save Changes" type="Emphasized" icon="sap-icon://save" press=".onSaveChanges"/>
                        </OverflowToolbar>
                    </headerToolbar>
                    <columns>
                        <Column width="180px"><Text text="Team ID"/></Column>
                        <Column minScreenWidth="200px"><Text text="Team Name"/></Column>
                        <Column minScreenWidth="300px"><Text text="Description"/></Column>
                        <Column minScreenWidth="200px"><Text text="Manager"/></Column>
                    </columns>
                    <items>
                        <ColumnListItem>
                            <cells>
                                <Label text="{adminService>teamId}" design="Bold"/>
                                <Input value="{adminService>name}"/>
                                <Input value="{adminService>description}"/>
                                <ComboBox selectedKey="{adminService>manager_ID}" items="{adminService>/Users}">
                                    <core:Item key="{adminService>ID}" text="{adminService>name}"/>
                                </ComboBox>
                            </cells>
                        </ColumnListItem>
                    </items>
                </Table>
            </VBox>
        </content>
    </Page>
</mvc:View>
