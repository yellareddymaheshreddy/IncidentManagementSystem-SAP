<mvc:View
    controllerName="com.amista.incidentmanagement.incidentmanagement.controller.Alerts"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:f="sap.f"
    xmlns:core="sap.ui.core">
    <Page
    title="Active Outage Alerts"
    showNavButton="true"
    navButtonPress=".onBack">

    <content>
        <VBox class="sapUiMediumMargin">

            <Table
                id="alertsTable"
                items="{alertsModel>/value}"
                growing="true"
                noDataText="All systems functional. No active critical outages detected."
                inset="false">

                <headerToolbar>
                    <OverflowToolbar>

                        <Title
                            text="System Outage Alerts"
                            level="H2"/>

                        <ToolbarSpacer/>

                        <Button
                            text="Refresh"
                            icon="sap-icon://refresh"
                            type="Transparent"
                            press=".onRefresh"/>

                    </OverflowToolbar>
                </headerToolbar>

                <columns>

                    <Column width="35%">
                        <Text text="Outage Details"/>
                    </Column>

                    <Column width="8rem" hAlign="Center">
                        <Text text="Priority"/>
                    </Column>

                    <Column width="8rem" hAlign="Center">
                        <Text text="Severity"/>
                    </Column>

                    <Column width="8rem" hAlign="Center">
                        <Text text="Age"/>
                    </Column>

                    <Column width="12rem" hAlign="Center">
                        <Text text="Logged At"/>
                    </Column>

                    <Column width="12rem" hAlign="Center">
                        <Text text="Actions"/>
                    </Column>

                </columns>

                <items>

                    <ColumnListItem vAlign="Middle">

                        <cells>

                            <VBox class="sapUiSmallMarginTop sapUiSmallMarginBottom">

                                <Title
                                    text="{alertsModel>title}"
                                    level="H5"/>

                                <Text
                                    text="{alertsModel>description}"
                                    maxLines="2"
                                    class="sapUiTinyMarginTop"/>

                            </VBox>

                            <ObjectStatus
                                text="{alertsModel>priority}"
                                state="Error"/>

                            <ObjectStatus
                                text="{alertsModel>severity}"
                                state="Warning"/>

                            <ObjectNumber
                                number="{alertsModel>ageMinutes}"
                                unit="Min"
                                state="Error"/>

                            <Text
                                text="{path:'alertsModel>createdAt', formatter:'.formatAlertTime'}"/>

                            <Button
                                text="Investigate"
                                icon="sap-icon://search"
                                type="Emphasized"
                                press=".onInvestigate"/>

                        </cells>

                    </ColumnListItem>

                </items>

            </Table>

        </VBox>

    </content>

</Page>
</mvc:View>
