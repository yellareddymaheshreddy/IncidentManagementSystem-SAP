<mvc:View
    controllerName="com.amista.incidentmanagement.incidentmanagement.controller.CreateIncident"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:f="sap.ui.layout.form"
    xmlns:core="sap.ui.core">

    <Page title="Create Incident">

        <content>

            <f:SimpleForm
                editable="true"
                layout="ResponsiveGridLayout">

                <Title text="Incident Information"/>

                <Label text="Title"/>
                <Input
                    id="titleInput"
                    required="true"/>

                <Label text="Description"/>
                <TextArea
                    id="descriptionInput"
                    rows="5"
                    required="true"/>

                <Label text="Severity"/>
                <Select
                    id="severitySelect"
                    required="true">

                    <items>

                        <core:Item
                            key="Low"
                            text="Low"/>

                        <core:Item
                            key="Medium"
                            text="Medium"/>

                        <core:Item
                            key="High"
                            text="High"/>

                        <core:Item
                            key="Critical"
                            text="Critical"/>

                    </items>

                </Select>

                <Label text="Business Impact"/>
                <Input
                    id="businessImpactInput"
                    placeholder="e.g. Order processing unavailable"/>

                <Label text="Affected Users"/>
                <Input
                    id="affectedUsersInput"
                    type="Number"
                    value="0"/>

                <Label text="Customer Impact"/>
                <Switch
                    id="customerImpactSwitch"/>

                <Label text="System"/>

                <Select
                    id="systemSelect"
                    items="{
                        path:'/Systems'
                    }">

                    <core:Item
                        key="{ID}"
                        text="{name}"/>

                </Select>

            </f:SimpleForm>

        </content>

        <footer>

            <Toolbar>

                <ToolbarSpacer/>

                <Button
                    text="Cancel"
                    press=".onCancel"/>

                <Button
                    text="Create Incident"
                    type="Emphasized"
                    press=".onSave"/>

            </Toolbar>

        </footer>

    </Page>

</mvc:View>