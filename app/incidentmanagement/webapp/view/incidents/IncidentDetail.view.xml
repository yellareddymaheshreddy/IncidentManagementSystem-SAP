<mvc:View
    controllerName="com.amista.incidentmanagement.incidentmanagement.controller.IncidentDetail"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:l="sap.ui.layout"
>
    <Page
        title="Incident Details"
        showNavButton="true"
        navButtonPress=".onNavBack"
    >
        <content>
            <!-- ═══ HERO HEADER ═══ -->
            <VBox
                class="sapUiMediumMarginBeginEnd sapUiSmallMarginTop sapUiSmallMarginBottom"
            >
                <!-- Title + Priority + Status row -->
                <HBox
                    justifyContent="SpaceBetween"
                    alignItems="Start"
                >
                    <Title
                        level="H1"
                        text="{= ${title} ? ${title} : 'Untitled Incident'}"
                        wrapping="true"
                        class="sapUiSmallMarginEnd"
                    />
                    <VBox
                        alignItems="End"
                        class="sapUiNoFlexItemShrink"
                    >
                        <ObjectNumber
                            number="{= ${priority} ? ${priority} : '—'}"
                            state="{path:'priority', formatter:'.formatter.formatPriorityState'}"
                            unit="Priority"
                            emphasized="true"
                        />
                        <ObjectStatus
                            text="{= ${status} ? ${status} : '—'}"
                            state="{path:'status', formatter:'.formatter.formatStatusState'}"
                            class="sapUiTinyMarginTop"
                        />
                    </VBox>
                </HBox>

                <!-- Description -->
                <Text
                    text="{= ${description} ? ${description} : 'No description provided.'}"
                    wrapping="true"
                    class="sapUiSmallMarginTop"
                />

                <!-- Meta row: ID · Created At -->
                <HBox
                    wrap="Wrap"
                    class="sapUiSmallMarginTop"
                    alignItems="Center"
                >
                    <HBox
                        alignItems="Center"
                        class="sapUiSmallMarginEnd"
                    >
                        <core:Icon
                            src="sap-icon://tag"
                            class="sapUiTinyMarginEnd"
                        />
                        <Label
                            text="Incident ID:"
                            class="sapUiTinyMarginEnd"
                        />
                        <Text text="{= ${incidentId} ? ${incidentId} : '—'}" />
                    </HBox>
                    <HBox alignItems="Center">
                        <core:Icon
                            src="sap-icon://appointment-2"
                            class="sapUiTinyMarginEnd"
                        />
                        <Label
                            text="Created:"
                            class="sapUiTinyMarginEnd"
                        />
                        <Text text="{= ${createdAt} ? ${createdAt} : '—'}" />
                    </HBox>
                </HBox>
            </VBox>

            <!-- ═══ ROW 1: ASSIGNMENT | BUSINESS IMPACT ═══ -->
            <l:Grid
                defaultSpan="L6 M6 S12"
                class="sapUiMediumMarginBeginEnd sapUiSmallMarginTop"
            >
                <l:content>
                    <!-- Assignment -->
                    <Panel headerText="Assignment">
                        <VBox
                            class="sapUiSmallMarginBeginEnd sapUiSmallMarginTopBottom"
                        >
                            <Label
                                text="Reported By"
                                design="Bold"
                            />
                            <HBox
                                alignItems="Center"
                                class="sapUiTinyMarginTop sapUiSmallMarginBottom"
                            >
                                <core:Icon
                                    src="sap-icon://person-placeholder"
                                    size="1.5rem"
                                    class="sapUiSmallMarginEnd"
                                />
                                <Link
                                    text="{= ${reportedBy/name} ? ${reportedBy/name} : '—'}"
                                    press=".onReportedByPress"
                                />
                            </HBox>

                            <Label
                                text="Assigned To"
                                design="Bold"
                            />
                            <HBox
                                alignItems="Center"
                                class="sapUiTinyMarginTop"
                            >
                                <core:Icon
                                    src="sap-icon://person-placeholder"
                                    size="1.5rem"
                                    class="sapUiSmallMarginEnd"
                                />
                                <Link
                                    text="{= ${assignedTo/name} ? ${assignedTo/name} : '—'}"
                                    press=".onAssignedToPress"
                                />
                            </HBox>
                        </VBox>
                    </Panel>

                    <!-- Business Impact -->
                    <Panel headerText="Business Impact">
                        <VBox
                            class="sapUiSmallMarginBeginEnd sapUiSmallMarginTopBottom"
                        >
                            <Label
                                text="Impact Description"
                                design="Bold"
                            />
                            <Text
                                text="{= ${businessImpact} ? ${businessImpact} : '—'}"
                                wrapping="true"
                                class="sapUiTinyMarginTop sapUiSmallMarginBottom"
                            />

                            <l:Grid defaultSpan="L6 M6 S12">
                                <l:content>
                                    <VBox>
                                        <Label
                                            text="Affected Users"
                                            design="Bold"
                                        />
                                        <ObjectNumber
                                            number="{= ${affectedUsers} !== undefined ? ${affectedUsers} : 0}"
                                            class="sapUiTinyMarginTop"
                                        />
                                    </VBox>
                                    <VBox>
                                        <Label
                                            text="Customer Impact"
                                            design="Bold"
                                        />
                                        <ObjectStatus
                                            text="{= ${customerImpact} ? ${customerImpact} : 'None'}"
                                            state="{= ${customerImpact} ? 'Error' : 'Success'}"
                                            class="sapUiTinyMarginTop"
                                        />
                                    </VBox>
                                </l:content>
                            </l:Grid>

                            <l:Grid
                                defaultSpan="L6 M6 S12"
                                class="sapUiSmallMarginTop"
                            >
                                <l:content>
                                    <VBox>
                                        <Label
                                            text="Is Duplicate"
                                            design="Bold"
                                        />
                                        <ObjectStatus
                                            text="{= ${isDuplicate} ? 'Yes' : 'No'}"
                                            state="{= ${isDuplicate} ? 'Warning' : 'Success'}"
                                            class="sapUiTinyMarginTop"
                                        />
                                    </VBox>
                                    <VBox>
                                        <Label
                                            text="Master Incident"
                                            design="Bold"
                                        />

                                        <!-- Show link with arrow only when masterIncident exists -->
                                        <HBox
                                            alignItems="Center"
                                            class="sapUiTinyMarginTop"
                                            visible="{= !!${masterIncident/ID} }"
                                        >
                                            <Link
                                                text="{= ${masterIncident/title} ? ${masterIncident/title} : 'View Master Incident'}"
                                                press=".onNavToMasterIncident"
                                                emphasized="true"
                                            />
                                            <core:Icon
                                                src="sap-icon://arrow-right"
                                                class="sapUiTinyMarginBegin"
                                                color="Neutral"
                                            />
                                        </HBox>

                                        <!-- Fallback when no master incident linked -->
                                        <Text
                                            text="—"
                                            visible="{= !${masterIncident/ID} }"
                                            class="sapUiTinyMarginTop"
                                        />
                                    </VBox>
                                </l:content>
                            </l:Grid>
                        </VBox>
                    </Panel>
                </l:content>
            </l:Grid>

            <!-- ═══ SLA TRACKING — FULL WIDTH 4-COL ═══ -->
            <Panel
                headerText="SLA Tracking"
                class="sapUiMediumMarginBeginEnd sapUiSmallMarginTop"
            >
                <l:Grid
                    defaultSpan="L3 M6 S12"
                    class="sapUiSmallMarginBeginEnd sapUiSmallMarginTopBottom"
                >
                    <l:content>
                        <VBox>
                            <Label
                                text="Response Due"
                                design="Bold"
                            />
                            <Text
                                text="{= ${responseDueAt} ? ${responseDueAt} : '—'}"
                                class="sapUiTinyMarginTop"
                            />
                        </VBox>
                        <VBox>
                            <Label
                                text="Resolution Due"
                                design="Bold"
                            />
                            <Text
                                text="{= ${resolutionDueAt} ? ${resolutionDueAt} : '—'}"
                                class="sapUiTinyMarginTop"
                            />
                        </VBox>
                        <VBox>
                            <Label
                                text="Responded At"
                                design="Bold"
                            />
                            <Text
                                text="{= ${respondedAt} ? ${respondedAt} : 'Not yet'}"
                                class="sapUiTinyMarginTop"
                            />
                        </VBox>
                        <VBox>
                            <Label
                                text="Resolved At"
                                design="Bold"
                            />
                            <Text
                                text="{= ${resolvedAt} ? ${resolvedAt} : 'Not yet'}"
                                class="sapUiTinyMarginTop"
                            />
                        </VBox>
                    </l:content>
                </l:Grid>
            </Panel>
            <!-- Comments -->
            <Panel
                headerText="Comments"
                class="sapUiMediumMarginBeginEnd sapUiSmallMarginTop sapUiSmallMarginBottom"
            >
                <List
                    items="{comments}"
                    noDataText="No comments yet"
                    showNoData="true"
                >
                    <CustomListItem>
                        <HBox
                            alignItems="Start"
                            class="sapUiSmallMarginBeginEnd sapUiSmallMarginTopBottom"
                        >
                            <core:Icon
                                src="sap-icon://person-placeholder"
                                size="1.5rem"
                                class="sapUiSmallMarginEnd"
                            />
                            <VBox>
                                <Link
                                    text="{= ${user/name} ? ${user/name} : 'Unknown User'}"
                                    target="{user/ID}"
                                    press=".onUserPress"
                                />
                                <Text
                                    text="{= ${comment} ? ${comment} : ''}"
                                    wrapping="true"
                                    class="sapUiTinyMarginTop"
                                />
                                <ObjectStatus
                                    text="{= ${createdAt} ? ${createdAt} : ''}"
                                    icon="sap-icon://appointment-2"
                                    class="sapUiTinyMarginTop"
                                />
                            </VBox>
                        </HBox>
                    </CustomListItem>
                </List>
                <VBox class="sapUiMediumMargin">
                    <TextArea
                        id="commentInput"
                        rows="3"
                        width="100%"
                        placeholder="Write a comment..."
                    />

                    <HBox
                        justifyContent="End"
                        class="sapUiSmallMarginTop"
                    >
                        <Button
                            text="Add Comment"
                            icon="sap-icon://comment"
                            type="Emphasized"
                            press=".onAddComment"
                        />
                    </HBox>
                </VBox>
            </Panel>
        </content>
    </Page>
</mvc:View>
