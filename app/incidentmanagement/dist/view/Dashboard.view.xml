<mvc:View
    xmlns:cards="sap.f.cards"
    controllerName="com.amista.incidentmanagement.incidentmanagement.controller.Dashboard"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:f="sap.f"
    xmlns:layout="sap.ui.layout"
    xmlns:core="sap.ui.core"
    xmlns:viz="sap.viz.ui5.controls"
    xmlns:viz.data="sap.viz.ui5.data"
    xmlns:viz.feeds="sap.viz.ui5.controls.common.feeds"
    xmlns:m="sap.m"
    xmlns:c="sap.suite.ui.microchart"
>
    <Page title="Incident Monitoring Dashboard">
        <content>
            <VBox class="sapUiMediumMargin">
                <!-- Header -->

                <Title
                    text="Operations Overview"
                    level="H1"
                />

                <Text
                    text="Monitor incidents, alerts, SLA compliance and operational trends."
                />

                <!-- KPI Cards -->

                <layout:Grid
    defaultSpan="XL3 L3 M6 S12"
    hSpacing="1"
    vSpacing="1"
    class="sapUiMediumMarginTop">

    <!-- Total Incidents -->
    <f:Card height="8rem" class="dashboardKpiCard">
        <f:content>
            <HBox
                justifyContent="SpaceBetween"
                alignItems="Center"
                class="sapUiMediumMargin">

                <VBox>
                    <Text text="Total Incidents" />
                    <Title
                        text="{dashboard>/totalIncidents}"
                        level="H1" />
                    <Text text="All incidents" />
                </VBox>

                <core:Icon
                    src="sap-icon://activity-items"
                    size="2.5rem"
                    color="#5CBAE5" />
            </HBox>
        </f:content>
    </f:Card>

    <!-- Open Incidents -->
    <f:Card height="8rem" class="dashboardKpiCard">
        <f:content>
            <HBox
                justifyContent="SpaceBetween"
                alignItems="Center"
                class="sapUiMediumMargin">

                <VBox>
                    <Text text="Open Incidents" />
                    <Title
                        text="{dashboard>/openIncidents}"
                        level="H1" />
                    <Text text="Needs attention" />
                </VBox>

                <core:Icon
                    src="sap-icon://warning2"
                    size="2.5rem"
                    color="#E9730C" />
            </HBox>
        </f:content>
    </f:Card>

    <!-- Critical Incidents -->
    <f:Card height="8rem" class="dashboardKpiCard">
        <f:content>
            <HBox
                justifyContent="SpaceBetween"
                alignItems="Center"
                class="sapUiMediumMargin">

                <VBox>
                    <Text text="Critical Incidents" />
                    <Title
                        text="{dashboard>/criticalIncidents}"
                        level="H1" />
                    <Text text="Immediate action" />
                </VBox>

                <core:Icon
                    src="sap-icon://alert"
                    size="2.5rem"
                    color="#BB0000" />
            </HBox>
        </f:content>
    </f:Card>

    <!-- SLA Breaches -->
    <f:Card height="8rem" class="dashboardKpiCard">
        <f:content>
            <HBox
                justifyContent="SpaceBetween"
                alignItems="Center"
                class="sapUiMediumMargin">

                <VBox>
                    <Text text="SLA Breaches" />
                    <Title
                        text="{dashboard>/slaBreaches}"
                        level="H1" />
                    <Text text="Compliance risk" />
                </VBox>

                <core:Icon
                    src="sap-icon://lateness"
                    size="2.5rem"
                    color="#BB0000" />
            </HBox>
        </f:content>
    </f:Card>

</layout:Grid>

                <layout:Grid
                    defaultSpan="XL4 L4 M6 S12"
                    hSpacing="1"
                    vSpacing="1"
                >
                    <m:Text
                        text="Incident Status Summary"
                        class="sapUiSmallMargin"
                    >
                        <m:layoutData>
                            <layout:GridData span="XL12 L12 M12 S12" />
                        </m:layoutData>
                    </m:Text>

                    <m:FlexBox
                        width="20rem"
                        height="12rem"
                        alignItems="Start"
                        justifyContent="SpaceBetween"
                    >
                        <m:items>
                            <c:InteractiveDonutChart displayedSegments="5">
                                <c:segments>
                                    <c:InteractiveDonutChartSegment
                                        label="New"
                                        value="{= ${chart>/value/2/count} }"
                                        displayedValue="{= ${chart>/value/2/count} }"
                                    />

                                    <c:InteractiveDonutChartSegment
                                        label="Open"
                                        value="{= ${chart>/value/4/count} }"
                                        displayedValue="{= ${chart>/value/4/count} }"
                                    />

                                    <c:InteractiveDonutChartSegment
                                        label="Assigned"
                                        value="{= ${chart>/value/3/count} }"
                                        displayedValue="{= ${chart>/value/3/count} }"
                                    />

                                    <c:InteractiveDonutChartSegment
                                        label="In Progress"
                                        value="{= ${chart>/value/1/count} }"
                                        displayedValue="{= ${chart>/value/1/count} }"
                                    />

                                    <c:InteractiveDonutChartSegment
                                        label="Resolved"
                                        value="{= ${chart>/value/0/count} }"
                                        displayedValue="{= ${chart>/value/0/count} }"
                                    />
                                </c:segments>
                            </c:InteractiveDonutChart>
                        </m:items>
                    </m:FlexBox>

                    <viz:VizFrame
                        id="incidentStatusChart"
                        vizType="column"
                        width="100%"
                        height="400px"
                    >
                        <viz:dataset>
                            <viz.data:FlattenedDataset data="{trend>/value}">
                                <viz.data:dimensions>
                                    <viz.data:DimensionDefinition
                                        name="Date"
                                        value="{trend>DATE}"
                                    />
                                </viz.data:dimensions>

                                <viz.data:measures>
                                    <viz.data:MeasureDefinition
                                        name="Incidents"
                                        value="{trend>INCIDENTCOUNT}"
                                    />
                                </viz.data:measures>
                            </viz.data:FlattenedDataset>
                        </viz:dataset>

                        <viz:feeds>
                            <viz.feeds:FeedItem
                                uid="valueAxis"
                                type="Measure"
                                values="Incidents"
                            />

                            <viz.feeds:FeedItem
                                uid="categoryAxis"
                                type="Dimension"
                                values="Date"
                            />
                        </viz:feeds>
                    </viz:VizFrame>

                    <viz:VizFrame
                        id="slaBreachChart"
                        vizType="column"
                        width="100%"
                        height="400px"
                    >
                        <viz:dataset>
                            <viz.data:FlattenedDataset data="{sla>/value}">
                                <viz.data:dimensions>
                                    <viz.data:DimensionDefinition
                                        name="Priority"
                                        value="{sla>PRIORITY}"
                                    />
                                </viz.data:dimensions>

                                <viz.data:measures>
                                    <viz.data:MeasureDefinition
                                        name="Breach Count"
                                        value="{sla>BREACHCOUNT}"
                                    />
                                </viz.data:measures>
                            </viz.data:FlattenedDataset>
                        </viz:dataset>

                        <viz:feeds>
                            <viz.feeds:FeedItem
                                uid="valueAxis"
                                type="Measure"
                                values="Breach Count"
                            />

                            <viz.feeds:FeedItem
                                uid="categoryAxis"
                                type="Dimension"
                                values="Priority"
                            />
                        </viz:feeds>
                    </viz:VizFrame>
                </layout:Grid>

                <!-- Active Alerts -->

                <f:Card class="sapUiMediumMarginTop">
                    <f:header>
                        <cards:Header title="Pending Alerts" />
                    </f:header>

                    <f:content>
                        <Table items="{alerts>/value}">
                            <columns>
                                <Column>
                                    <Text text="Title" />
                                </Column>

                                <Column>
                                    <Text text="Priority" />
                                </Column>

                                <Column>
                                    <Text text="Severity" />
                                </Column>

                                <Column>
                                    <Text text="Age (Minutes)" />
                                </Column>
                            </columns>

                            <items>
                                <ColumnListItem>
                                    <cells>
                                        <Text text="{alerts>title}" />

                                        <ObjectStatus
                                            text="{alerts>priority}"
                                            state="Error"
                                        />

                                        <ObjectStatus
                                            text="{alerts>severity}"
                                            state="Error"
                                        />

                                        <ObjectNumber
                                            number="{alerts>ageMinutes}"
                                        />
                                    </cells>
                                </ColumnListItem>
                            </items>
                        </Table>
                    </f:content>
                </f:Card>
            </VBox>
        </content>
    </Page>
</mvc:View>
