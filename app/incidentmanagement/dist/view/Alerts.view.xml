<mvc:View
    controllerName="com.amista.incidentmanagement.incidentmanagement.controller.Alerts"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:f="sap.f"
    xmlns:core="sap.ui.core">
    <Page title="Active Outage Alerts" showNavButton="true" navButtonPress=".onBack">
        <content>
            <VBox class="sapUiMediumMargin">
                <Table
                    id="alertsTable"
                    items="{alertsModel>/value}"
                    noDataText="All systems functional. No active critical outages detected."
                    class="sapUiResponsiveMargin">
                    <headerToolbar>
                        <OverflowToolbar>
                            <Title text="System Outage Alerts" level="H2"/>
                            <ToolbarSpacer/>
                            <Button text="Refresh Alerts" icon="sap-icon://refresh" type="Ghost" press=".onRefresh"/>
                        </OverflowToolbar>
                    </headerToolbar>
                    <columns>
                        <Column minScreenWidth="250px" ><Text text="Outage Details"/></Column>
                        <Column width="110px" hAlign="Center"><Text text="Priority"/></Column>
                        <Column width="110px" hAlign="Center"><Text text="Severity"/></Column>
                        <Column width="130px" hAlign="Center"><Text text="Age (Minutes)"/></Column>
                        <Column width="180px" hAlign="End"><Text text="Log Time"/></Column>
                        <Column width="180px" hAlign="Center"><Text text="Actions"/></Column>
                    </columns>
                    <items>
                        <ColumnListItem>
                            <cells>
                                <VBox>
                                    <Text text="{alertsModel>title}"/>
                                    <Text text="{alertsModel>description}" class="textMuted sapUiTinyMarginTop"/>
                                </VBox>
                                <ObjectStatus text="{alertsModel>priority}" state="Error"/>
                                <ObjectStatus text="{alertsModel>severity}" state="Error"/>
                                <ObjectNumber number="{alertsModel>ageMinutes}" unit="Min" state="Error"/>
                                <Text text="{path: 'alertsModel>createdAt', formatter: '.formatAlertTime'}"/>
                                <Button text="Investigate Root Cause" type="Emphasized" icon="sap-icon://search" press=".onInvestigate"/>
                            </cells>
                        </ColumnListItem>
                    </items>
                </Table>
            </VBox>
        </content>
    </Page>
</mvc:View>
