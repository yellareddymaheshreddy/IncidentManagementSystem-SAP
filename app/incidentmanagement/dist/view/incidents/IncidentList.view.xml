<mvc:View
    controllerName="com.amista.incidentmanagement.incidentmanagement.controller.IncidentList"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
>
    <Page title="Incidents Hub">
        <content>
            <VBox class="sapUiMediumMargin">
                <Table
                    id="incidentTable"
                    items="{
    path: '/Incidents',
    parameters: {
        $expand: 'system,reportedBy,assignedTo'
    }
}"
                    mode="SingleSelectMaster"
                    itemPress=".onIncidentPress"
                    growing="true"
                    growingThreshold="15"
                    class="sapUiResponsiveContentPadding"
                >
                    <headerToolbar>
                        <OverflowToolbar>
                            <Title
                                text="{view>/tableTitle}"
                                level="H2"
                            />
                            <ToolbarSpacer />
                            <SearchField
                                id="searchField"
                                search=".onSearch"
                                width="30%"
                                placeholder="Search by title, description..."
                            />
                            <Select
                                id="statusFilter"
                                change=".onFilterChange"
                                forceSelection="false"
                                name="statusFilter"
                                selectedKey="All"
                            >
                                <items>
                                    <core:Item
                                        key="All"
                                        text="All Statuses"
                                    />
                                    <core:Item
                                        key="New"
                                        text="New"
                                    />
                                    <core:Item
                                        key="Open"
                                        text="Open"
                                    />
                                    <core:Item
                                        key="Assigned"
                                        text="Assigned"
                                    />
                                    <core:Item
                                        key="InProgress"
                                        text="In Progress"
                                    />
                                    <core:Item
                                        key="Resolved"
                                        text="Resolved"
                                    />
                                    <core:Item
                                        key="Closed"
                                        text="Closed"
                                    />
                                </items>
                            </Select>
                            <Select
                                id="priorityFilter"
                                change=".onFilterChange"
                                forceSelection="false"
                                selectedKey="All"
                            >
                                <items>
                                    <core:Item
                                        key="All"
                                        text="All Priorities"
                                    />
                                    <core:Item
                                        key="P1"
                                        text="P1 - Critical"
                                    />
                                    <core:Item
                                        key="P2"
                                        text="P2 - High"
                                    />
                                    <core:Item
                                        key="P3"
                                        text="P3 - Medium"
                                    />
                                    <core:Item
                                        key="P4"
                                        text="P4 - Low"
                                    />
                                    <core:Item
                                        key="P5"
                                        text="P5 - Very Low"
                                    />
                                </items>
                            </Select>
                            <Button
                                icon="sap-icon://clear-filter"
                                tooltip="Reset Filters"
                                press=".onResetFilters"
                            />
                            <Button
                                text="Report Incident"
                                icon="sap-icon://add"
                                type="Emphasized"
                                press=".onCreateIncident"
                            />
                            <Button
                                id="saveAssignmentsBtn"
                                text="Save Assignments"
                                icon="sap-icon://save"
                                type="Accept"
                                visible="{user>/isAdmin}"
                                press=".onSaveAssignments"
                            />
                        </OverflowToolbar>
                    </headerToolbar>

                    <columns>
                        <Column width="110px">
                            <Text text="Incident ID" />
                        </Column>
                        <Column minScreenWidth="200px">
                            <Text text="Title" />
                        </Column>
                        <Column minScreenWidth="120px">
                            <Text text="System" />
                        </Column>
                        <Column
                            width="110px"
                            hAlign="Center"
                        >
                            <Text text="Priority" />
                        </Column>
                        <Column
                            width="130px"
                            hAlign="Center"
                        >
                            <Text text="Status" />
                        </Column>
                        <Column
                            minScreenWidth="120px"
                            visible="{user>/isAdmin}"
                        >
                            <Text text="Reported By" />
                        </Column>
                        <Column
                            minScreenWidth="160px"
                            visible="{user>/isAdmin}"
                        >
                            <Text text="Assigned To" />
                        </Column>
                        <Column
                            width="150px"
                            hAlign="End"
                        >
                            <Text text="Created Date" />
                        </Column>
                    </columns>

                    <items>
                        <ColumnListItem type="Navigation">
                            <cells>
                                <Label
                                    text="{incidentId}"
                                    design="Bold"
                                />
                                <VBox>
                                    <Text text="{title}" />
                                    <Text
                                        text="{description}"
                                        maxLines="1"
                                        class="sapUiTinyMarginTop textMuted"
                                    />
                                </VBox>
                                <Text text="{system/name}" />
                                <ObjectStatus
                                    text="{priority}"
                                    state="{path: 'priority', formatter: '.formatPriorityState'}"
                                />
                                <ObjectStatus
                                    text="{status}"
                                    state="{path: 'status', formatter: '.formatStatusState'}"
                                    icon="{path: 'status', formatter: '.formatStatusIcon'}"
                                />
                                <Text text="{reportedBy/name}" />
                                <VBox>
                                    <ComboBox
                                        selectedKey="{assignedTo_ID}"
                                        items="{path: 'adminService>/Users', templateShareable: false}"
                                        visible="{user>/isAdmin}"
                                        width="150px"
                                    >
                                        <core:Item
                                            key="{adminService>ID}"
                                            text="{adminService>name}"
                                        />
                                    </ComboBox>
                                    <Text
                                        text="{assignedTo/name}"
                                        visible="{= !${user>/isAdmin} }"
                                    />
                                </VBox>
                                <Text
                                    text="{path: 'createdAt', formatter: '.formatDate'}"
                                />
                            </cells>
                        </ColumnListItem>
                    </items>
                </Table>
            </VBox>
        </content>
    </Page>
</mvc:View>
