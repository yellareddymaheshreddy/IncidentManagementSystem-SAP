<mvc:View
    controllerName="com.amista.incidentmanagement.incidentmanagement.controller.UserDetail"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:uxap="sap.uxap"
    xmlns:core="sap.ui.core">
    
    <uxap:ObjectPageLayout id="userDetailLayout" showTitleInHeaderContent="true" showFooter="false">
        <uxap:headerTitle>
            <uxap:ObjectPageDynamicHeaderTitle>
                <uxap:expandedHeading>
                    <Title text="{adminService>name}" wrapping="true" class="sapUiSmallMarginEnd"/>
                </uxap:expandedHeading>
                <uxap:snappedHeading>
                    <FlexBox fitContainer="true" alignItems="Center">
                        <Title text="{adminService>name}" wrapping="true"/>
                    </FlexBox>
                </uxap:snappedHeading>
                <uxap:navigationActions>
                    <Button icon="sap-icon://decline" type="Transparent" press=".onClose" tooltip="Close column" />
                </uxap:navigationActions>
            </uxap:ObjectPageDynamicHeaderTitle>
        </uxap:headerTitle>

        <uxap:headerContent>
            <FlexBox wrap="Wrap" fitContainer="true" alignItems="Stretch">
                <VBox class="sapUiLargeMarginEnd sapUiSmallMarginBottom">
                    <Title text="User ID" class="sapUiTinyMarginBottom"/>
                    <Text text="{adminService>ID}"/>
                </VBox>
                <VBox class="sapUiLargeMarginEnd sapUiSmallMarginBottom">
                    <Title text="Email" class="sapUiTinyMarginBottom"/>
                    <Link text="{adminService>email}" href="mailto:{adminService>email}"/>
                </VBox>
                <VBox class="sapUiLargeMarginEnd sapUiSmallMarginBottom">
                    <Title text="Support Team" class="sapUiTinyMarginBottom"/>
                    <Text text="{adminService>supportTeam/name}"/>
                </VBox>
                <VBox class="sapUiLargeMarginEnd sapUiSmallMarginBottom">
                    <Title text="Role" class="sapUiTinyMarginBottom"/>
                    <ObjectStatus text="{adminService>role}" state="{= ${adminService>role} === 'Admin' ? 'Error' : 'Success'}"/>
                </VBox>
            </FlexBox>
        </uxap:headerContent>

        <uxap:sections>
            <uxap:ObjectPageSection title="Reported Incidents">
                <uxap:subSections>
                    <uxap:ObjectPageSubSection>
                        <uxap:blocks>
                            <Table id="reportedIncidentsTable" items="{path: 'adminService>reportedIncidents'}">
                                <columns>
                                    <Column><Text text="Incident"/></Column>
                                    <Column><Text text="Priority"/></Column>
                                    <Column><Text text="Status"/></Column>
                                </columns>
                                <items>
                                    <ColumnListItem type="Navigation" press=".onIncidentPress">
                                        <cells>
                                            <VBox>
                                                <Text text="{adminService>title}"/>
                                                <Text text="{adminService>ID}" class="sapUiTinyMarginTop textMuted"/>
                                            </VBox>
                                            <Text text="{adminService>priority}"/>
                                            <ObjectStatus text="{adminService>status}"/>
                                        </cells>
                                    </ColumnListItem>
                                </items>
                            </Table>
                        </uxap:blocks>
                    </uxap:ObjectPageSubSection>
                </uxap:subSections>
            </uxap:ObjectPageSection>

            <uxap:ObjectPageSection title="Assigned Incidents">
                <uxap:subSections>
                    <uxap:ObjectPageSubSection>
                        <uxap:blocks>
                            <Table id="assignedIncidentsTable" items="{path: 'adminService>assignedIncidents'}">
                                <headerToolbar>
                                    <OverflowToolbar>
                                        <ToolbarSpacer/>
                                        <Button text="Assign Incident" type="Default" icon="sap-icon://employee-approvals" press=".onAssignIncident" visible="{userModel>/isAdmin}"/>
                                    </OverflowToolbar>
                                </headerToolbar>
                                <columns>
                                    <Column><Text text="Incident"/></Column>
                                    <Column><Text text="Priority"/></Column>
                                    <Column><Text text="Status"/></Column>
                                </columns>
                                <items>
                                    <ColumnListItem type="Navigation" press=".onIncidentPress">
                                        <cells>
                                            <VBox>
                                                <Text text="{adminService>title}"/>
                                                <Text text="{adminService>ID}" class="sapUiTinyMarginTop textMuted"/>
                                            </VBox>
                                            <Text text="{adminService>priority}"/>
                                            <ObjectStatus text="{adminService>status}"/>
                                        </cells>
                                    </ColumnListItem>
                                </items>
                            </Table>
                        </uxap:blocks>
                    </uxap:ObjectPageSubSection>
                </uxap:subSections>
            </uxap:ObjectPageSection>
        </uxap:sections>
    </uxap:ObjectPageLayout>
</mvc:View>
