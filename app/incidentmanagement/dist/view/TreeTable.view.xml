<mvc:View
    controllerName="com.amista.incidentmanagement.incidentmanagement.controller.TreeTable"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.ui.table"
    xmlns:m="sap.m">

    <m:Page title="Incident Hierarchy">

        <m:content>

            <TreeTable
                id="incidentTreeTable"
                selectionMode="Single"
                visibleRowCount="4"
                rows="{
                    path:'tree>/incidents',
                    parameters:{
                        arrayNames:['dublicates']
                    }
                }">

                <columns>

                    <Column width="300px">
                        <m:Label text="Title"/>
                        <template>
                            <m:Text text="{tree>title}"/>
                        </template>
                    </Column>

                    <Column width="250px">
                        <m:Label text="Description"/>
                        <template>
                            <m:Text text="{tree>description}"/>
                        </template>
                    </Column>

                    <Column width="120px">
                        <m:Label text="Priority"/>
                        <template>
                            <m:ObjectStatus
                                text="{tree>priority}"/>
                        </template>
                    </Column>

                    <Column width="120px">
                        <m:Label text="Status"/>
                        <template>
                            <m:ObjectStatus
                                text="{tree>status}"/>
                        </template>
                    </Column>

                    <Column width="120px">
                        <m:Label text="Severity"/>
                        <template>
                            <m:Text text="{tree>severity}"/>
                        </template>
                    </Column>

                    <Column width="120px">
                        <m:Label text="Affected Users"/>
                        <template>
                            <m:ObjectNumber
                                number="{tree>affectedUsers}"/>
                        </template>
                    </Column>

                    <Column width="150px">
                        <m:Label text="Customer Impact"/>
                        <template>
                            <m:ObjectStatus
                                text="{tree>customerImpact}"
                                state="{= ${tree>customerImpact} ? 'Error' : 'Success' }"/>
                        </template>
                    </Column>

                    <Column width="180px">
                        <m:Label text="Created At"/>
                        <template>
                            <m:Text text="{tree>createdAt}"/>
                        </template>
                    </Column>

                </columns>

            </TreeTable>

        </m:content>

    </m:Page>

</mvc:View>