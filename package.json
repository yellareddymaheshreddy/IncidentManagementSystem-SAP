{
  "name": "IncidentManagement",
  "version": "1.0.0",
  "dependencies": {
    "@cap-js/hana": "^2",
    "@sap/cds": "^9",
    "@sap/xssec": "^4.13.0"
  },
  "devDependencies": {
    "@cap-js/sqlite": "^2.4",
    "@sap/cds-dk": "^9",
    "cds-plugin-ui5": "^0.17.0",
    "mbt": "^1.2.49",
    "rimraf": "^5.0.5"
  },
  "scripts": {
    "start": "cds-serve",
    "watch-incidentmanagement": "cds watch --open com.amista.incidentmanagement.incidentmanagement/index.html?sap-ui-xx-viewCache=false --livereload false",
    "undeploy": "cf undeploy IncidentManagement --delete-services --delete-service-keys --delete-service-brokers",
    "build": "rimraf resources mta_archives && mbt build --mtar archive",
    "deploy": "cf deploy mta_archives/archive.mtar --retries 1",
    "dev": "cds watch --profile hybrid",
    "hana": "cds build --for hana && cds deploy --to hana"
  },
  "private": true,
  "cds": {
    "requires": {
      "[hybrid]": {
        "db": "hana"
      },
      "auth": {
        "kind": "mocked",
        "users": {
          "admin": {
            "password": "admin",
            "id": "4c1e5c79-9c07-4dfa-afc2-6d7546f8e1bd",
            "roles": ["Admin"]
          },
          "user": {
            "password": "user",
            "id": "0143a8de-05af-4002-a15a-0f4de35033db",
            "roles": ["User"]
          }
        }
        
        
      }
    }
  },
  "workspaces": [
    "app/*"
  ]
}
